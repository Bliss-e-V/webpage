---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import { EventTimeline } from "@components/events/EventTimeline";
import EventTimelineAutoScroll from "@components/events/EventTimelineAutoScroll.astro";
import { getTimelineEvents } from "@components/data/events";

const workshopEvents = getTimelineEvents("workshop");
---

<Layout
    title="Workshops"
    description="Join BLISS Berlin's hands-on workshops on cutting-edge AI and machine learning topics. Learn practical skills and explore the latest technologies."
    eventTimelineScroll={workshopEvents.length > 0}
>
    <EventTimelineAutoScroll events={workshopEvents}>
    <Breadcrumb
        crumbs={[
            { name: "Workshops", href: "/workshops" }
        ]}
    />
    <h1
        class="mt-6 sm:mt-8 text-4xl sm:text-5xl text-transparent bg-clip-text bg-red-right font-bold"
    >
        Workshops
    </h1>
    <div
        class="w-full mb-10 max-w-full border-b sm:border-b-0 h-[0px] sm:h-[1px] bg-gradient-to-r from-gray-200 to-transparent ..."
    >
    </div>
    <div class="mb-10">
        <p class="text-secondary text-md sm:text-lg">
            We irregularly team up with companies to host hands-on workshops on cutting-edge AI and machine learning topics. Learn practical skills and explore the latest technologies.
        </p>
    </div>
    <EventTimeline
        client:load
        events={workshopEvents}
        autoScrollToNext
        expandLabel="Details"
        emptyMessage="No workshops scheduled. Stay tuned!"
    />
    </EventTimelineAutoScroll>
</Layout>

