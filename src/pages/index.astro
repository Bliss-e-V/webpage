---
import Layout from "../layouts/Layout.astro";
import BackgroundAnimation from "../components/BackgroundAnimation.astro";
import Landing from "../components/Landing.astro";
import AboutUs from "@components/AboutUs.astro";
import Events from "@components/EventsSection.astro";
import Teaser from "@components/TeaserSection.astro";
import Arrow from "@components/Arrow.astro";
import Partners from "@components/Partners.astro";
import Members from "@components/Members.astro";
---

<Layout
  title="BLISS - Berlin Learning & Intelligent Systems Society"
  description="BLISS is Berlin's research-focused AI non-profit organization, connecting passionate individuals in machine learning through weekly reading groups, speaker and diversity events, and hackathons. Join our thriving research ecosystem today."
>
  <main>
    <BackgroundAnimation />
    <Landing />
    <Events />
    <Teaser />
    <AboutUs />
    <Members />
    <Partners />
    <Arrow />
  </main>
</Layout>
