<div
  id="canvasContainer"
  class="fixed top-0 left-0 w-screen h-screen md:fixed -z-10 flex flex-row items-center justify-center"
>
  <canvas id="bgWebglCanvas" aria-hidden="true"></canvas>
</div>

<script>
  const canvas = document.getElementById("bgWebglCanvas") as HTMLCanvasElement | null;
  if (!canvas) throw new Error("bgWebglCanvas missing");

  const start = () => {
    void import("../lib/background-webgl").then(({ initBackgroundWebGL }) => {
      initBackgroundWebGL({ canvas });
    });
  };

  if (typeof globalThis.requestIdleCallback === "function") {
    globalThis.requestIdleCallback(start, { timeout: 2000 });
  } else {
    globalThis.addEventListener("load", start, { once: true });
  }
</script>
