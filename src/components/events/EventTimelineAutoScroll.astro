---
import type { BlissEvent } from "@components/data/events";
import { toEventScrollRefs } from "@lib/event-scroll";

interface Props {
    events: BlissEvent[];
}

const { events } = Astro.props;
const eventRefs = toEventScrollRefs(events);
---

{
    eventRefs.length > 0 && (
        <>
            <noscript>
                <style is:inline>
                    html.event-timeline-scroll-pending .container {
                        visibility: visible !important;
                    }
                </style>
            </noscript>
            <script is:inline define:vars={{ eventRefs }}>
                if ("scrollRestoration" in history) {
                    history.scrollRestoration = "manual";
                }
                window.__blissEventScrollRefs = eventRefs;
            </script>
            <slot />
            <script is:inline>
                (function () {
                    var refs = window.__blissEventScrollRefs;
                    if (!refs || refs.length === 0) return;

                    var idParam = new URLSearchParams(window.location.search).get("id");
                    var today = new Date();
                    today.setHours(0, 0, 0, 0);

                    var targetId = null;
                    if (idParam) {
                        for (var i = 0; i < refs.length; i++) {
                            var event = refs[i];
                            if (
                                event.id === idParam ||
                                (event.seriesNumber != null &&
                                    String(event.seriesNumber) === idParam) ||
                                event.id.endsWith("-" + idParam)
                            ) {
                                targetId = event.id;
                                break;
                            }
                        }
                    } else {
                        var next = null;
                        for (var j = 0; j < refs.length; j++) {
                            var entry = refs[j];
                            var date = new Date(entry.date);
                            if (date < today) continue;
                            if (!next || date < new Date(next.date)) {
                                next = entry;
                            }
                        }
                        targetId = next ? next.id : null;
                    }

                    document.documentElement.classList.add("event-timeline-scrolled");
                    document.documentElement.classList.remove("event-timeline-scroll-pending");

                    function getHeaderHeight() {
                        var header = document.getElementById("header");
                        return header ? header.getBoundingClientRect().height : 0;
                    }

                    function scrollToEvent(el) {
                        var rect = el.getBoundingClientRect();
                        var top = Math.max(0, window.scrollY + rect.top - getHeaderHeight());
                        window.scrollTo({ top: top, left: 0, behavior: "instant" });
                    }

                    if (targetId) {
                        var el = document.getElementById(targetId);
                        if (el) {
                            scrollToEvent(el);
                            requestAnimationFrame(function () {
                                scrollToEvent(el);
                            });
                            window.__blissEventScrollTargetId = targetId;
                        }
                    }

                    delete window.__blissEventScrollRefs;
                    document.dispatchEvent(new Event("bliss-header-sync"));
                })();
            </script>
        </>
    )
}

{eventRefs.length === 0 && <slot />}
