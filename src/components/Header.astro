---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div
  id="header"
  class:list={[
    "fixed top-0 z-40 flex items-center justify-center w-full select-none mr-10 ml-10 border-b bg-black/70",
    compact
      ? "h-20 backdrop-blur-md border-border"
      : "h-40 border-transparent",
  ]}
>
  <div class="container flex justify-between">
    <div class="flex items-center justify-start space-x-[50px]">
      <a id="logo" href="/">
        <picture>
          <source srcset="/assets/bliss-logo.webp" type="image/webp" />
          <img
            alt="bliss logo"
            src="/assets/bliss-logo.png"
            width={80}
            height={22}
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      </a>
    </div>
    <div id="menu" class="flex items-center space-x-3 md:space-x-7 pl-2 md:pl-0">
      <a
        id="speakerSeriesLink"
        href="/speaker-series"
        class="tracking-wider no-underline text-secondary hover:text-primary transition-colors"
      >
        <p class="text-center text-xs sm:text-base">Speaker Series</p>
      </a>
      <a
        id="readingGroupLink"
        href="/reading-group"
        class="tracking-wider no-underline text-secondary hover:text-primary transition-colors"
      >
        <p class="text-center text-xs sm:text-base">Reading Group</p>
      </a>
      <a
        id="workshopsLink"
        href="/workshops"
        class="tracking-wider no-underline text-secondary hover:text-primary transition-colors"
      >
        <p class="text-center text-xs sm:text-base">Workshops</p>
      </a>

    </div>
  </div>
</div>

<style>
  #join-link:hover {
    text-decoration-color: transparent;
  }

  #header {
    transition:
      height 0.3s ease,
      backdrop-filter 0.3s ease,
      border-color 0.3s ease;
  }

  html.event-timeline-page #header {
    height: 5rem;
    transition: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #header {
      transition: none;
    }
  }
</style>

<script>
  const header = document.getElementById("header")!;
  const speakerSeriesLink: HTMLElement = document.getElementById("speakerSeriesLink")!;
  const readingGroupLink: HTMLElement = document.getElementById("readingGroupLink")!;
  const workshopsLink: HTMLElement = document.getElementById("workshopsLink")!;

  const allLinks: HTMLElement[] = [speakerSeriesLink, readingGroupLink, workshopsLink];

  function isEventTimelinePage() {
    return document.documentElement.classList.contains("event-timeline-page");
  }

  function animateHeader() {
    if (isEventTimelinePage()) {
      header.classList.remove("h-40");
      header.classList.add("h-20", "backdrop-blur-md", "border-border");
      header.classList.remove("border-transparent");
      return;
    }

    if (window.scrollY > 0) {
      header.classList.remove("h-40");
      header.classList.add("h-20", "backdrop-blur-md", "border-border");
      header.classList.remove("border-transparent");
    } else {
      header.classList.remove("h-20", "backdrop-blur-md", "border-border");
      header.classList.add("h-40", "border-transparent");
    }
  }

  function setActiveLink(activeLink: HTMLElement | null) {
    allLinks.forEach((link) => {
      link.classList.remove("text-primary");
      link.classList.add("text-secondary");
    });

    if (activeLink) {
      activeLink.classList.remove("text-secondary");
      activeLink.classList.add("text-primary");
    }
  }

  function handleRoute() {
    const linkMap: Record<string, HTMLElement> = {
      "/speaker-series": speakerSeriesLink,
      "/reading-group": readingGroupLink,
      "/workshops": workshopsLink,
    };

    setActiveLink(linkMap[window.location.pathname] ?? null);
  }

  function handleScroll() {
    animateHeader();
  }

  animateHeader();
  handleRoute();
  document.addEventListener("scroll", handleScroll, { passive: true });
  document.addEventListener("bliss-header-sync", handleScroll);
</script>
